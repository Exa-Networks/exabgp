option:file:conf-sr-policy.conf
# EOR for ipv4 sr-policy (AFI=1, SAFI=73)
1:cmd:announce eor ipv4 sr-policy
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000149
# EOR for ipv6 sr-policy (AFI=2, SAFI=73)
1:cmd:announce eor ipv6 sr-policy
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF001E0200000007900F0003000249
# IPv4 SR Policy: MPLS preference + binding-sid + segment type-A (label 16001)
1:cmd:announce ipv4 sr-policy distinguisher 0 color 100 endpoint 10.0.0.1 next-hop 192.0.2.1 preference 100 binding-sid mpls 24000 segment-list weight 1 segment type-a mpls 16001
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF006902000000524001010040020040050400000064C01728000F00240C060000000000640D06100005DC01008000110009060000000000010106000003E81100800E1600014904C0000201006000000000000000640A000001
# IPv4 SR Policy: SRv6 binding-sid + type-B segment with endpoint-behavior + names
1:cmd:announce ipv4 sr-policy distinguisher 1 color 200 endpoint 10.0.0.2 next-hop 192.0.2.1 preference 200 srv6-binding-sid fc00::1 segment-list weight 2 segment type-b srv6 fc00::1 endpoint-behavior 65 32 0 16 0 policy-name "my-policy" candidate-path-name "primary"
1:raw:
# IPv4 SR Policy: multiple segment lists
1:cmd:announce ipv4 sr-policy distinguisher 0 color 300 endpoint 10.0.0.3 next-hop 192.0.2.1 preference 300 segment-list weight 1 segment type-a mpls 16001 segment-list weight 2 segment type-a mpls 16002
1:raw:FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0075020000005E4001010040020040050400000064C01734000F00300C0600000000012C8000110009060000000000010106000003E811008000110009060000000000020106000003E82100800E1600014904C00002010060000000000000012C0A000003
# IPv6 SR Policy: SRv6 segment type-B
1:cmd:announce ipv6 sr-policy distinguisher 0 color 100 endpoint 2001:db8::1 next-hop 2001:db8::2 preference 100 segment-list weight 1 segment type-b srv6 2001:db8:1::1

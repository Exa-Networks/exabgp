from:5
to:main

input:<<<
# Example 5.x config with nlri-mpls
process announce {
    encoder text;
    run ./run/test.py;
}

neighbor 10.0.0.1 {
    router-id 1.2.3.4;
    local-as 65000;
    peer-as 65001;

    family {
        ipv4 nlri-mpls;
        ipv6 nlri-mpls;
        ipv4 unicast;
    }

    api {
        processes [ announce ];
    }
}
>>>

